{
  "private": true,
  "name": "commune-critter",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test:logic": "esbuild tools/smoke-test.ts --bundle --platform=node --format=esm --outfile=dist/smoke-test.mjs && node dist/smoke-test.mjs",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.8",
    "@devvit/web": "0.13.8",
    "@hono/node-server": "2.0.8",
    "devvit": "0.13.8",
    "hono": "4.12.28",
    "phaser": "4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.19",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.3"
  }
}